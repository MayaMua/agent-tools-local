# Local Vision — Configuration
# Copy this file to .env and edit to match your setup:
#   cp .env.example .env

# Backend: "ollama" or "lmstudio"
VISION_BACKEND=lmstudio

# Server base URL
#   Ollama default:  http://localhost:11434
#   LM Studio default: http://localhost:1234  (check actual port with `lms server status`)
VISION_SERVER_URL=http://localhost:11234

# Model name — must support vision (multimodal) input
#   Ollama example:  glm-ocr:latest  (or llava:latest, bakllava, etc.)
#   LM Studio example: allenai/olmocr-2-7b  (or any VL model you've downloaded)
VISION_MODEL=allenai/olmocr-2-7b

# Default prompt when none is specified
VISION_DEFAULT_PROMPT=Describe this image in detail.

# Response tuning
VISION_MAX_TOKENS=1024
VISION_TEMPERATURE=0.1
