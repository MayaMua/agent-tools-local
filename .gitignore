# ── Secrets & local config ────────────────────────────────────────────────
# Never commit real .env files (CookieCloud creds, local server URLs, etc.)
.env
**/.env
!**/.env.example

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments (multi-GB — never commit) ────────────────────────
.venv/
**/.venv/
venv/

# ── uv ────────────────────────────────────────────────────────────────────
# uv.lock IS committed (reproducible builds); caches are not
.uv-cache/

# ── Model weights & downloaded data ───────────────────────────────────────
*.gguf
*.safetensors
*.bin

# ── Media / document artifacts (tool outputs) ─────────────────────────────
*.mp3
*.mp4
*.m4a
*.wav
*.webm
*.m4s
*.vtt
*/audio.*/
*/audio_segments/
*/metadata.json
*/transcript.txt
links.txt

# ── IDE / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
